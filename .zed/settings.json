{
    "languages": {
        "Python": {
            "language_servers": ["pyrefly", "!pyright", "!pylsp"]
        }
    },
    "lsp": {
        "pyrefly": {
            "binary": {
                "path": ".venv/bin/pyrefly",
                "arguments": ["lsp"]
            },
            "settings": {
                "python": {
                    "pyrefly": {
                        "displayTypeErrors": "force-on"
                    }
                }
            }
        }
    }
}

{
  "languages": {
    "Python": {
      "language_servers": [
        "pyrefly",
        "!pyright",
        "!pylsp"
      ]
    }
  },
  "lsp": {
    "pyrefly": {
      "binary": {
        "arguments": [
          "lsp"
        ],
        "path": ".venv/bin/pyrefly"
      },
      "settings": {
        "python": {
          "pyrefly": {
            "displayTypeErrors": "force-on"
          }
        }
      }
    }
  }
}
